# ── Required ──────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Agent ─────────────────────────────────────────────────────────────────────
AGENT_MODEL=gpt-4o
DB_PATH=data/checkpoints.db

# ── Voice ─────────────────────────────────────────────────────────────────────
VOICE_TTS_MODEL=gpt-4o-mini-tts
VOICE_TTS_VOICE=ash
VOICE_REALTIME_MODEL=gpt-4o-realtime-preview-2024-12-17

# ── Optional: Travel demo (falls back to mock data if not set) ────────────────
OPENWEATHER_API_KEY=
